generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DATABASE_DIRECT_URL")
  url       = env("DATABASE_POOL_URL")
}

model AdminUser {
  id          String    @id @default(cuid()) @db.VarChar(50)
  name        String    @db.VarChar(100)
  email       String    @unique @db.VarChar(100)
  password    String    @db.VarChar(100)
  phoneNumber String?   @db.VarChar(15)
  role        String    @default("STAFF")
  products    Product[]
}

model Category {
  id          String    @id @default(cuid()) @db.VarChar(50)
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String     @id @default(cuid()) @db.VarChar(50)
  slug        String     @unique @db.VarChar(50)
  title       String     @unique @db.VarChar(50)
  price       Float
  imgUrl      String?
  description String?
  isFeatured  Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdBy   AdminUser? @relation(fields: [creatorId], references: [id])
  creatorId   String?    @db.VarChar(50)
  category    Category?  @relation(fields: [categoryId], references: [id])
  categoryId  String?    @db.VarChar(50)
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Customer {
  id        String   @id @default(cuid()) @db.VarChar(50)
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(100)
  phone     String?  @db.VarChar(15)
  address   String?
  city      String?
  zipCode   String?
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid()) @db.VarChar(50)
  total           Float
  status          String      @default("PENDING")
  shippingAddress String
  phone           String      @db.VarChar(15)
  paymentMethod   String      @default("CARD")
  note            String?
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String      @db.VarChar(50)
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid()) @db.VarChar(50)
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  productId String  @db.VarChar(50)
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String  @db.VarChar(50)
}
